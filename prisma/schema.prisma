generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("user")
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clinicId])
}

model Clinic {
  id               String      @id @default(cuid())
  name             String
  kommoSubdomain   String      @unique
  kommoToken       String
  clinicorpUser       String?
  clinicorpToken      String?
  clinicorpBusinessId String?
  // Toggles de integração
  clinicorpAutoCreatePatient Boolean @default(false)
  clinicorpWebhookEnabled    Boolean @default(true)
  // Meta Ads (Marketing API - somente leitura)
  metaAccessToken    String?
  metaTokenExpiresAt DateTime?
  metaAdAccountId    String?
  // Google Ads (Marketing API - somente leitura)
  googleAdsRefreshToken  String?
  googleAdsCustomerId    String?
  pipelineId       String?
  stageAgendamento String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  users            User[]
  leads            Lead[]
  patients         Patient[]
  procedures       Procedure[]
  adCampaignData   AdCampaignData[]
}

model Lead {
  id              String    @id @default(cuid())
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id])
  kommoLeadId     String
  name            String
  phone           String?
  email           String?
  // UTMs
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  // Canal de Prospeccao (Kommo custom field)
  canalProspeccao String?
  // Patient classification: true = first-time (acquisition), false = returning (retention)
  isNewPatient    Boolean?
  // Status
  channel         String    @default("organic") // "campaign" | "organic"
  kommoStatus     String?
  kommoPipelineId String?
  // Matching
  patientId       String?
  patient         Patient?  @relation(fields: [patientId], references: [id])
  // Timestamps
  kommoCreatedAt  DateTime?
  agendamentoAt   DateTime?
  // Appointment data from Kommo custom fields
  appointmentDate     String?
  appointmentTime     String?
  appointmentProfId   String?
  clinicorpAppointmentId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([clinicId, kommoLeadId])
  @@index([clinicId, channel])
  @@index([clinicId, utmCampaign])
  @@index([clinicId, isNewPatient])
}

model Patient {
  id                 String      @id @default(cuid())
  clinicId           String
  clinic             Clinic      @relation(fields: [clinicId], references: [id])
  clinicorpPatientId String?
  name               String
  phone              String?
  cpf                String?
  // UTMs herdadas do lead
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  utmContent         String?
  utmTerm            String?
  // Canal de prospeccao herdado do lead
  canalProspeccao    String?
  // Relações
  leads              Lead[]
  procedures         Procedure[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([clinicId, clinicorpPatientId])
  @@index([clinicId, phone])
}

model Procedure {
  id                   String    @id @default(cuid())
  clinicId             String
  clinic               Clinic    @relation(fields: [clinicId], references: [id])
  patientId            String
  patient              Patient   @relation(fields: [patientId], references: [id])
  clinicorpProcedureId String?
  name                 String
  value                Float
  status               String    @default("pending") // "pending" | "approved" | "completed" | "cancelled"
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([clinicId, status])
  @@index([patientId])
}

model AdCampaignData {
  id           String   @id @default(cuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  platform     String   // "meta" | "google"
  campaignId   String   // ID da campanha na plataforma
  campaignName String
  date         DateTime @db.Date
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  spend        Float    @default(0)
  currency     String   @default("BRL")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([clinicId, platform, campaignId, date])
  @@index([clinicId, date])
  @@index([clinicId, campaignName])
}

model WebhookLog {
  id        String   @id @default(cuid())
  source    String   // "kommo" | "clinicorp"
  event     String
  payload   Json
  status    String   @default("received") // "received" | "processed" | "error"
  error     String?
  createdAt DateTime @default(now())
}
